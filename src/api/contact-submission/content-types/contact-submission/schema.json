{
    "kind": "collectionType",
    "collectionName": "contact_submissions",
    "info": {
        "singularName": "contact-submission",
        "pluralName": "contact-submissions",
        "displayName": "Kontaktanfrage",
        "description": "Eingehende Nachrichten \u00fcber das Kontaktformular"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "maxLength": 255
        },
        "email": {
            "type": "email",
            "required": true
        },
        "phone": {
            "type": "string",
            "maxLength": 50
        },
        "message": {
            "type": "text",
            "required": true
        },
        "read": {
            "type": "boolean",
            "default": false
        },
        "ip_address": {
            "type": "string",
            "maxLength": 50,
            "private": true
        }
    }
}